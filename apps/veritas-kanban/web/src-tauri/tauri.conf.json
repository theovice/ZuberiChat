{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZuberiChat",
  "version": "0.1.0",
  "identifier": "com.zuberichat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZuberiChat",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
