{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zuberi",
  "version": "0.1.0",
  "identifier": "com.zuberichat.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zuberi",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/zuberi.ico",
      "icons/icon.png"
    ]
  }
}
