{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zuberi",
  "version": "1.0.8",
  "identifier": "com.zuberichat.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zuberi",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost http://localhost:11434 ws://127.0.0.1:18789; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/zuberi.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "both",
        "languages": ["English"]
      }
    }
  },
  "plugins": {}
}
