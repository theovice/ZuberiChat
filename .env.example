# Feishu vs Lark public cloud endpoint selector
FEISHU_DOMAIN=feishu

# Feishu app credentials (required)
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# Optional for webhook challenge/signature verification
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# websocket (recommended for local dev) or webhook
FEISHU_MODE=websocket

# Required when FEISHU_MODE=webhook
PORT=3000

# Agent backend endpoint that receives normalized chat events
AGENT_ENDPOINT=http://localhost:8787/chat
